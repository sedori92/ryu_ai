# ============================================================
# .env.example - 환경변수 템플릿 파일
# ============================================================
# 사용 방법:
#   1. 이 파일을 복사해서 이름을 ".env"로 바꾸세요.
#   2. 각 항목의 "=" 뒤에 실제 값을 입력하세요.
#   3. .env 파일은 절대 GitHub에 올리지 마세요! (.gitignore에 등록되어 있음)
# ============================================================

# OpenAI API 키
# 발급처: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Supabase 프로젝트 URL
# 발급처: Supabase 프로젝트 설정 → API → Project URL
SUPABASE_URL=

# Supabase Service Role Key (비밀 키 - 절대 프론트엔드에 노출 금지)
# 발급처: Supabase 프로젝트 설정 → API → Project API keys (service_role)
SUPABASE_SERVICE_ROLE_KEY=
